{
  "name": "ducky",
  "version": "1.0.0",
  "description": "A minimal ngrok-like tunneling system",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @ducky.wtf/shared && npm run build -w @ducky/database && npm run build -w @ducky/server && npm run build -w @ducky/web-backend && npm run build -w @ducky.wtf/cli && npm run build -w @ducky/web-frontend",
    "build:server": "npm run build -w @ducky/server",
    "build:cli": "npm run build -w @ducky.wtf/cli",
    "link:cli": "npm run build:cli && npm run link -w @ducky.wtf/cli",
    "build:database": "npm run build -w @ducky/database",
    "build:web": "npm run build -w @ducky/web-backend && npm run build -w @ducky/web-frontend",
    "dev": "./dev-all.sh",
    "dev:server": "npm run dev -w @ducky/server",
    "dev:cli": "npm run dev -w @ducky.wtf/cli",
    "dev:web-backend": "npm run dev -w @ducky/web-backend",
    "dev:web-frontend": "npm run dev -w @ducky/web-frontend",
    "test:e2e": "./test-e2e.sh",
    "start:server": "npm run start -w @ducky/server",
    "start:cli": "npm run start -w @ducky.wtf/cli",
    "start:web-backend": "npm run start -w @ducky/web-backend",
    "logs": "tail -f logs/*.log",
    "logs:server": "tail -f logs/server.log",
    "logs:backend": "tail -f logs/web-backend.log",
    "stop": "pkill -f 'node.*@ducky' || true",
    "clean": "rm -rf packages/*/dist logs/*.log logs/*.pid",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,json}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
