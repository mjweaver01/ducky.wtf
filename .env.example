# Server Configuration
PORT=3000
TUNNEL_PORT=4000
TUNNEL_DOMAIN=tunnel.example.com

# Authentication
# Option 1: Environment variable (simple, for dev/testing)
VALID_TOKENS=your-secret-token-1,your-secret-token-2

# Option 2: AWS Secrets Manager (recommended for production)
# AWS_SECRET_NAME=ngrok-clone/valid-tokens
# AWS_REGION=us-east-1

# Security Limits
MAX_TUNNELS_PER_TOKEN=5
MAX_CONCURRENT_REQUESTS=100
RATE_LIMIT_MAX_REQUESTS=1000
REQUEST_TIMEOUT=30000

# Logging
LOG_FILE=/var/log/ngrok-clone/server.log
LOG_LEVEL=info

# Node Environment
NODE_ENV=production
