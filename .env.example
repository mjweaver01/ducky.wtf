# Database Configuration (use these when running Postgres via docker-compose.dev.yml)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ducky
DATABASE_USER=ducky
DATABASE_PASSWORD=ducky_password
DATABASE_SSL=false

# Server Configuration
PORT=3000
TUNNEL_PORT=3001
BASE_DOMAIN=localhost
NODE_ENV=development

# Security
JWT_SECRET=your-secret-key-change-in-production
SESSION_SECRET=your-session-secret-change-in-production

# Stripe (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Stripe Price IDs (created in Stripe Dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_ENTERPRISE_YEARLY=price_xxx

# Logging
LOG_LEVEL=info
LOG_FILE=

# Rate Limiting
MAX_TUNNELS_PER_USER=10
MAX_TUNNELS_PER_TOKEN=5
MAX_CONCURRENT_REQUESTS=100
RATE_LIMIT_MAX_REQUESTS=1000
REQUEST_TIMEOUT=30000
MAX_REQUEST_SIZE=10485760

# Web UI
WEB_PORT=3002
WEB_URL=http://localhost:5173
VITE_API_URL=http://localhost:3002

# Email Configuration (for contact form)
# For Gmail: Use your Gmail address and an App Password (not your regular password)
# Generate App Password at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
CONTACT_EMAIL_TO=your-email@gmail.com
